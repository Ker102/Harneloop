{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harneloop.local/schemas/attempt-plan.schema.json",
  "title": "Harneloop Attempt Plan",
  "type": "object",
  "required": ["schema_version", "id", "goal", "method", "actions", "expected_artifacts", "success_checks", "created_at"],
  "properties": {
    "schema_version": { "type": "string" },
    "id": { "type": "string" },
    "goal": { "type": "string", "minLength": 1 },
    "method": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "success_checks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
