{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harneloop.local/schemas/candidate-record.schema.json",
  "title": "Harneloop Candidate Record",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "base_version",
    "plane",
    "validation_tier",
    "status",
    "summary",
    "created_at",
    "changes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "id": { "type": "string", "pattern": "^cand-[0-9]{4,}$" },
    "base_version": { "type": ["string", "null"] },
    "kind": { "type": "string" },
    "plane": {
      "type": "string",
      "enum": ["target_harness", "evaluation", "infrastructure", "mixed"]
    },
    "validation_tier": {
      "type": "string",
      "enum": ["structural", "targeted", "representative", "full"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "accumulating", "ready", "validating", "needs_rebase", "promoted", "rejected"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "status_updated_at": { "type": "string" },
    "promoted_at": { "type": "string" },
    "promoted_version": { "type": "string" },
    "changes": {
      "type": "object",
      "required": ["mode", "path"],
      "properties": {
        "mode": { "type": "string", "enum": ["overlay"] },
        "path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "rebase_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "rebased_at"],
        "properties": {
          "from": { "type": ["string", "null"] },
          "to": { "type": ["string", "null"] },
          "rebased_at": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
